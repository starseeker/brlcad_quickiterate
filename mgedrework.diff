-    if (s->dbip == DBI_NULL)
-	return;
-
-    sedraw = 0;
-    ++s->update_views;
-
-    switch (MEDIT(s)->edit_flag) {
-
-	case IDLE:
-	    /* do nothing more */
-	    --s->update_views;
-	    break;
-
-	case ECMD_DSP_SCALE_X:
-	    dsp_scale(s, (struct rt_dsp_internal *)MEDIT(s)->es_int.idb_ptr, MSX);
-	    break;
-	case ECMD_DSP_SCALE_Y:
-	    dsp_scale(s, (struct rt_dsp_internal *)MEDIT(s)->es_int.idb_ptr, MSY);
-	    break;
-	case ECMD_DSP_SCALE_ALT:
-	    dsp_scale(s, (struct rt_dsp_internal *)MEDIT(s)->es_int.idb_ptr, MSZ);
