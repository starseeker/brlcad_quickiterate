-    }
-
-    /* build new point */
-    BU_ALLOC(newpp, struct wdb_pipe_pnt);
-    newpp->l.magic = WDB_PIPESEG_MAGIC;
-    newpp->pp_od = first->pp_od;
-    newpp->pp_id = first->pp_id;
