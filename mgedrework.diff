-	case ECMD_DSP_FNAME:
-	    {
-		struct rt_dsp_internal *dsp =
-		    (struct rt_dsp_internal *)MEDIT(s)->es_int.idb_ptr;
-		const char *fname;
-		struct stat stat_buf;
-		b_off_t need_size;
